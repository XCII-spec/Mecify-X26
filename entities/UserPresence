{
  "name": "UserPresence",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string",
      "description": "Email de l'utilisateur"
    },
    "is_online": {
      "type": "boolean",
      "default": false,
      "description": "En ligne ou non"
    },
    "last_seen": {
      "type": "string",
      "format": "date-time",
      "description": "Derni\u00e8re activit\u00e9"
    },
    "status": {
      "type": "string",
      "enum": [
        "online",
        "away",
        "busy",
        "offline"
      ],
      "default": "offline",
      "description": "Statut de pr\u00e9sence"
    }
  },
  "required": [
    "user_email"
  ]
}