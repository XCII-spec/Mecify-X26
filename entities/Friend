{
  "name": "Friend",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string",
      "description": "Email de l'utilisateur"
    },
    "friend_email": {
      "type": "string",
      "description": "Email de l'ami"
    },
    "friend_name": {
      "type": "string",
      "description": "Nom de l'ami"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "accepted",
        "blocked"
      ],
      "default": "pending",
      "description": "Statut de la relation"
    },
    "requested_by": {
      "type": "string",
      "description": "Email de celui qui a envoy\u00e9 la demande"
    }
  },
  "required": [
    "user_email",
    "friend_email",
    "requested_by"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "data.user_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "data.user_email": "{{user.email}}"
        },
        {
          "data.friend_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "data.user_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "data.user_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}