{
  "name": "Notification",
  "type": "object",
  "properties": {
    "recipient_email": {
      "type": "string",
      "description": "Email du destinataire"
    },
    "sender_email": {
      "type": "string",
      "description": "Email de l'exp\u00e9diteur"
    },
    "sender_name": {
      "type": "string",
      "description": "Nom de l'exp\u00e9diteur"
    },
    "type": {
      "type": "string",
      "enum": [
        "message",
        "comment",
        "like",
        "follow",
        "mention"
      ],
      "description": "Type de notification"
    },
    "content": {
      "type": "string",
      "description": "Contenu/aper\u00e7u"
    },
